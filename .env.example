# ============================================
# PLAN App — Environment Variables
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://plan:plan@localhost:5432/plan?schema=public

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Groq AI
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# Mini App
MINIAPP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# API Server
PORT=3001
NODE_ENV=development

# JWT (for session tokens)
JWT_SECRET=change-me-to-random-string

# Webhook (optional, for production)
# WEBHOOK_URL=https://your-domain.com/bot-webhook
