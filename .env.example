# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Public host (Render) ---
WEBHOOK_BASE_URL=https://plan-app.onrender.com

# --- Database ---
# Neon Postgres (https://neon.tech). Async driver, e.g.:
# postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=

# --- Groq ---
# Comma-separated list of Groq API keys (3+).
GROQ_API_KEYS=

# --- AI defaults ---
CRITIC_DEFAULT_MODE=confidence

# --- App ---
ENV=development
LOG_LEVEL=INFO
