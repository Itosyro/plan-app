# =============================================================================
# Sensitive files - DO NOT COMMIT
# =============================================================================

# Hermes credentials and secrets
.env
.env.*
credentials.json
*.pem
*.key

# API keys and tokens
api_keys.*
*token*
*secret*

# Session data (large, personal)
sessions/
*.db
*.db-journal

# Cron output (can contain sensitive data)
cron/output/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temp
tmp/
temp/
*.tmp

# =============================================================================
# Keep these (NOT sensitive)
# =============================================================================
# AGENTS.md and PROJECTS.md are intentionally committed - personal instructions
!AGENTS.md
!PROJECTS.md

# Keep Vault structure but not actual vault content
# (user will populate manually)
!Vault/.gitkeep

# Keep Projects structure
!Projects/.gitkeep
Projects/smartkey-router/

# Keep skills (they're public skills anyway)
!.hermes/