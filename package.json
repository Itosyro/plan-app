{
  "name": "plan-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:bot & npm run dev:api",
    "dev:bot": "tsx watch src/bot/main.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start:bot": "node dist/bot/main.js",
    "start:api": "node dist/api/server.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^5.8.0",
    "fastify": "^4.25.0",
    "grammy": "^1.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
