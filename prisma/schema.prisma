generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  username    String?
  firstName   String?
  lastName    String?
  languageCode String?
  timezone    String   @default("Europe/Moscow")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings    UserSettings?
  tasks       Task[]
  notes       Note[]
  projects    Project[]
  inboxEntries InboxEntry[]
  reminders   Reminder[]
  dailyPlans  DailyPlan[]
  aiRuns      AiRun[]
  taskEvents  TaskEvent[]
}

model UserSettings {
  id                           String  @id @default(cuid())
  userId                       String  @unique
  user                         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  remindersEnabled             Boolean @default(true)
  postProcessingSummaryEnabled Boolean @default(true)
  dailyDigestEnabled           Boolean @default(false)
  dailyDigestTime              String? @default("09:00")
  stuckTasksPingEnabled        Boolean @default(false)
  stuckTasksPingIntervalHours  Int?    @default(24)
  deleteTaskOnDone             Boolean @default(false)
  deleteNotesWithTask          Boolean @default(true)
  circlesViewEnabled           Boolean @default(true)
  columnViewEnabled            Boolean @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model InboxEntry {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType          String   @default("text")
  rawText             String?
  transcriptText      String?
  originalFileUrl     String?
  originalTelegramFileId String?
  mimeType            String?
  durationSeconds     Int?
  processingStatus    String   @default("pending")
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tasks               Task[]
  notes               Note[]
  aiRuns              AiRun[]
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  color     String?
  isArchived Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]
}

model Task {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxEntryId     String?
  inboxEntry       InboxEntry? @relation(fields: [inboxEntryId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title            String
  description      String?
  status           String    @default("inbox")
  priority         String    @default("medium")
  energyLevel      String    @default("medium")
  estimatedMinutes Int?
  scheduledFor     DateTime?
  deadlineAt       DateTime?
  sortOrder        Int?
  sourceText       String?
  completionNote   String?
  completedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  notes            Note[]
  reminders        Reminder[]
  dailyPlanItems   DailyPlanItem[]
  taskEvents       TaskEvent[]
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxEntryId String?
  inboxEntry InboxEntry? @relation(fields: [inboxEntryId], references: [id], onDelete: SetNull)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reminder {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type          String
  scheduledTime DateTime?
  isEnabled     Boolean  @default(true)
  metaJson      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DailyPlan {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now()) @db.Date
  summary         String?
  overloadWarning Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           DailyPlanItem[]

  @@unique([userId, date])
}

model DailyPlanItem {
  id          String    @id @default(cuid())
  dailyPlanId String
  dailyPlan   DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  slotLabel   String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
}

model TaskEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      String
  payloadJson Json?
  createdAt DateTime @default(now())
}

model AiRun {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxEntryId   String?
  inboxEntry    InboxEntry? @relation(fields: [inboxEntryId], references: [id], onDelete: SetNull)
  type          String
  model         String?
  promptVersion String?
  inputText     String?
  outputJson    Json?
  status        String   @default("started")
  errorMessage  String?
  createdAt     DateTime @default(now())
}
